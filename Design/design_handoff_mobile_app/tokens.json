{
  "$meta": {
    "name": "OfferBee Design System",
    "version": "1.0.0",
    "platform": "iOS 26 (Liquid Glass)",
    "description": "Design tokens for OfferBee — a credit-card benefits & annual-fee tracker. Two themes (Honey light, Onyx dark) over one fixed layout + type system."
  },
  "typography": {
    "families": {
      "display": "Source Serif 4",
      "text": "Public Sans",
      "mono": "IBM Plex Mono"
    },
    "styles": {
      "largeTitle": { "family": "display", "size": 34, "weight": 600, "letterSpacing": "-0.02em" },
      "title":      { "family": "display", "size": 24, "weight": 600, "letterSpacing": "-0.01em" },
      "figureL":    { "family": "mono",    "size": 40, "weight": 600, "letterSpacing": "-0.03em", "tabular": true },
      "figureM":    { "family": "mono",    "size": 30, "weight": 600, "tabular": true },
      "sectionLabel": { "family": "mono",  "size": 11, "weight": 500, "letterSpacing": "0.06em", "case": "uppercase" },
      "body":       { "family": "text",    "size": 15, "weight": 600 },
      "bodyRegular":{ "family": "text",    "size": 15, "weight": 400 },
      "subtext":    { "family": "text",    "size": 12.5, "weight": 400 },
      "button":     { "family": "text",    "size": 14, "weight": 600 },
      "caption":    { "family": "text",    "size": 12, "weight": 400 }
    }
  },
  "spacing": { "xs": 4, "sm": 8, "md": 12, "base": 16, "lg": 20, "xl": 24, "screenInset": 16, "rowPadY": 13, "rowPadX": 16 },
  "radius": { "badge": 8, "chip": 11, "button": 11, "card": 16, "cardLg": 18, "tabBar": 30, "pill": 9999 },
  "elevation": {
    "card": "0 0 0 1px {border}",
    "glassTabBar": "0 10px 30px rgba(33,29,22,0.16), inset 0 1px 0 rgba(255,255,255,0.6)",
    "glassBlur": "blur(22px) saturate(180%)",
    "glassOpacity": 0.6
  },
  "iconography": { "grid": 24, "stroke": 1.8, "caps": "round", "joins": "round", "style": "outlined" },
  "themes": {
    "honey": {
      "$label": "Honey — light, default",
      "background": "#FBF8F0",
      "surface": "#FFFEFB",
      "border": "#E8E1D2",
      "separator": "#ECE5D6",
      "ink": "#211D16",
      "secondary": "#6F6757",
      "tertiary": "#9A927F",
      "track": "#E4DECF",
      "accent": "#E8680E",
      "accentSoft": "#FBEAD5",
      "warning": "#B4693A",
      "warningSoft": "#F6E9DF",
      "alert": "#C0503F",
      "segmentedTrack": "#E9E3D6",
      "field": "#EDE7D9",
      "tabUnselected": "#A69C86",
      "glass": "rgba(251,248,240,0.60)",
      "navButton": "rgba(255,254,251,0.75)"
    },
    "onyx": {
      "$label": "Onyx — dark",
      "background": "#17181B",
      "surface": "#212328",
      "border": "#2E3036",
      "separator": "#282A2F",
      "ink": "#ECEBE6",
      "secondary": "#9C9A93",
      "tertiary": "#6E6C67",
      "track": "#2E3036",
      "accent": "#F59E3C",
      "accentSoft": "#3A2C17",
      "warning": "#D18A4E",
      "warningSoft": "#3A2E24",
      "alert": "#E0785F",
      "segmentedTrack": "#2A2C31",
      "field": "#26282C",
      "tabUnselected": "#6E6C67",
      "glass": "rgba(22,23,26,0.62)",
      "navButton": "rgba(255,255,255,0.08)"
    }
  },
  "semantic": {
    "positive": "accent",
    "success": "accentSoft",
    "expiring": "warning",
    "atRisk": "alert",
    "note": "Credit-card brand colors (card art) are content, not theme tokens, and never remap."
  }
}
